# Exclude non-.NET projects (biggest context bloat)
Cleansia.App/
cleansia_android/

# Exclude test projects (not needed for Functions build)
Cleansia.Tests/
Cleansia.IntegrationTests/
Cleansia.TestUtilities/

# Exclude IDE/tooling
**/.classpath
**/.dockerignore
**/.env
**/.git
**/.gitignore
**/.project
**/.settings
**/.toolstarget
**/.vs
**/.vscode
**/*.*proj.user
**/*.dbmdl
**/*.jfm
**/azds.yaml
**/charts
**/docker-compose*
**/Dockerfile*
**/node_modules
**/npm-debug.log
**/secrets.dev.yaml
**/values.dev.yaml
LICENSE
README.md

# Exclude build artifacts
**/bin
**/obj
**/publish