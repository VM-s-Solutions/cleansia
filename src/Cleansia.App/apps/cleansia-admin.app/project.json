{
  "name": "cleansia-admin.app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/cleansia-admin.app/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [],
      "options": {
        "outputPath": "dist/apps/cleansia-admin.app",
        "index": "apps/cleansia-admin.app/src/index.html",
        "browser": "apps/cleansia-admin.app/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/cleansia-admin.app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/cleansia-admin.app/src/assets",
          {
            "glob": "staticwebapp.config.json",
            "input": "apps/cleansia-admin.app/src",
            "output": "/"
          }
        ],
        "styles": [
          "apps/cleansia-admin.app/src/styles.scss",
          "libs/shared/assets/src/styles/cleansia-admin.scss"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "3mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "16kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/cleansia-admin.app/src/environments/environment.ts",
              "with": "apps/cleansia-admin.app/src/environments/environment.prod.ts"
            }
          ]
        },
        "staging": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "3mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "16kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/cleansia-admin.app/src/environments/environment.ts",
              "with": "apps/cleansia-admin.app/src/environments/environment.staging.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "port": 4201,
        "proxyConfig": "apps/cleansia-admin.app/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "cleansia-admin.app:build:production"
        },
        "development": {
          "buildTarget": "cleansia-admin.app:build:development"
        },
        "devremote": {
          "buildTarget": "cleansia-admin.app:build:development",
          "proxyConfig": "apps/cleansia-admin.app/proxy.devremote.conf.json"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "cleansia-admin.app:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/cleansia-admin.app/jest.config.ts",
        "tsConfig": "apps/cleansia-admin.app/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "cleansia-admin.app:build",
        "port": 4201,
        "staticFilePath": "dist/apps/cleansia-admin.app/browser",
        "spa": true
      }
    }
  }
}
