{
  "name": "cleansia.app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/cleansia.app/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "dependsOn": [],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/cleansia.app",
        "index": "apps/cleansia.app/src/index.html",
        "browser": "apps/cleansia.app/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/cleansia.app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": ["apps/cleansia.app/src/assets"],
        "styles": [
          "apps/cleansia.app/src/styles.scss",
          "libs/shared/assets/src/styles/cleansia-customer.scss"
        ]
      },
      "configurations": {
      "production": {
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "fileReplacements": [
            {
              "replace": "apps/cleansia.app/src/environments/environment.ts",
              "with": "apps/cleansia.app/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "2mb",
              "maximumError": "5mb"
            }
          ]
        },
        "development": {
          "optimization": false,
          "sourceMap": true,
          "namedChunks": true,
          "extractLicenses": false
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "cleansia.app:build:production"
        },
        "development": {
          "buildTarget": "cleansia.app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "cleansia.app:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/cleansia.app/jest.config.ts"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "cleansia.app:build",
        "port": 4200,
        "staticFilePath": "dist/apps/cleansia.app/browser",
        "spa": true
      }
    }
  }
}
