{
  "name": "components",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/components/src",
  "prefix": "cleansia",
  "projectType": "library",
  "tags": ["scope:shared type:ui"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/shared/components/ng-package.json",
        "styles": [
          "node_modules/primeng/resources/primeng.min.css",
          "node_modules/primeicons/primeicons.css",
          "/cleansia/src/Cleansia.App/apps/cleansia.app/src/styles.scss", "libs/shared/assets/src/shared-styles.scss"],
        "assets": ["../assets/logo.png"]
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/shared/components/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/shared/components/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/shared/components/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
