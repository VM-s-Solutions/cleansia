{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cleansia-partner/confirm-email": [
        "libs/cleansia-partner-features/confirm-email/src/index.ts"
      ],
      "@cleansia-partner/login": [
        "libs/cleansia-partner-features/login/src/index.ts"
      ],
      "@cleansia-partner/orders": [
        "libs/cleansia-partner-features/orders/src/index.ts"
      ],
      "@cleansia-partner/profile": [
        "libs/cleansia-partner-features/profile/src/index.ts"
      ],
      "@cleansia-partner/register": [
        "libs/cleansia-partner-features/register/src/index.ts"
      ],
      "@cleansia-partner/invoices": [
        "libs/cleansia-partner-features/invoices/src/index.ts"
      ],
      "@cleansia/assets": ["libs/shared/assets/src/index.ts"],
      "@cleansia/cleansia": ["libs/cleansia/src/index.ts"],
      "@cleansia/cleansia-services": ["libs/cleansia-services/src/index.ts"],
      "@cleansia/components": ["libs/shared/components/src/index.ts"],
      "@cleansia/directives": ["libs/shared/directives/src/index.ts"],
      "@cleansia/models": ["libs/shared/models/src/index.ts"],
      "@cleansia/pipes": ["libs/shared/pipes/src/index.ts"],
      "@cleansia/services": ["libs/core/services/src/index.ts"],
      "@cleansia/stores": ["libs/data-access/stores/src/index.ts"],
      "@cleansia/types": ["libs/shared/types/src/index.ts"],
      "@cleansia/utils": ["libs/shared/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
