{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cleansia/assets": ["libs/shared/assets/src/index.ts"],
      "@cleansia/cleansia": ["libs/cleansia/src/index.ts"],
      "@cleansia/components": ["libs/shared/components/src/index.ts"],
      "@cleansia/models": ["libs/shared/models/src/index.ts"],
      "@cleansia/services": ["libs/core/services/src/index.ts"],
      "@cleansia/stores": ["libs/data-access/stores/src/index.ts"],
      "@cleansia/utils": ["libs/shared/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
