<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded: title row + countdown + progress bar + time labels -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="12dp">

    <!-- Row 1: title + status label -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Status label on the right -->
        <TextView
            android:id="@+id/notification_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.04"
            android:textColor="#90A4AE" />

        <!-- Title + subtitle stacked -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/notification_status"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ECEFF1"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/notification_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="#90A4AE"
                android:ellipsize="end"
                android:maxLines="1" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Row 2: Large countdown timer -->
    <Chronometer
        android:id="@+id/notification_chronometer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:fontFamily="sans-serif-light"
        android:textColor="#ECEFF1" />

    <!-- Row 3: Progress bar -->
    <ProgressBar
        android:id="@+id/notification_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:max="1000"
        android:progress="0"
        android:progressDrawable="@drawable/notification_progress" />

    <!-- Row 4: elapsed | estimated -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/notification_elapsed_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:textSize="11sp"
            android:textColor="#78909C" />

        <TextView
            android:id="@+id/notification_estimated_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:textSize="11sp"
            android:textColor="#78909C" />
    </RelativeLayout>
</LinearLayout>
