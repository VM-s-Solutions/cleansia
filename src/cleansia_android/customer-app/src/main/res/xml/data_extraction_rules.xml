<?xml version="1.0" encoding="utf-8"?>
<!-- Same exclusions as backup_rules.xml (Android 12+ variant) — see there
     for what each file holds. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="cleansia_auth_tokens.xml" />
        <exclude domain="file" path="datastore/user_addresses.preferences_pb" />
        <exclude domain="file" path="datastore/push_token_state.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="cleansia_auth_tokens.xml" />
        <exclude domain="file" path="datastore/user_addresses.preferences_pb" />
        <exclude domain="file" path="datastore/push_token_state.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
