<?xml version="1.0" encoding="utf-8"?>
<!--
  sharedpref: cleansia_auth_tokens.xml (EncryptedSharedPreferences token store).
  database:   partner_notifications.db (per-account notification feed).
  datastore/: partner_user_profile (email/name/userId/role PII),
              partner_push_token_state, partner_order_checklists,
              partner_app_settings — excluded wholesale so future stores are
              opted out by default; name-based excludes rot when files move.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="datastore/" />
</full-backup-content>
