{
  "sourceLanguage": "en",
  "strings": {
    "error.address.already_exists": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You already have this address saved."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuto adresu už máte uloženou."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Túto adresu už máte uloženú."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ця адреса вже збережена."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот адрес уже сохранён."
          }
        }
      }
    },
    "error.address.invalid_length": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Address is too short or too long."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Adresa je příliš krátká nebo příliš dlouhá."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Adresa je príliš krátka alebo príliš dlhá."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Адреса занадто коротка або занадто довга."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Адрес слишком короткий или слишком длинный."
          }
        }
      }
    },
    "error.address.label_required": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please provide a label for this address."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadejte prosím název adresy."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadajte prosím názov tejto adresy."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Будь ласка, введіть назву для цієї адреси."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пожалуйста, введите название для этого адреса."
          }
        }
      }
    },
    "error.address.mapbox_coords_required": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please pick the address on the map."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvolte prosím adresu na mapě."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvoľte prosím adresu na mape."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть, будь ласка, адресу на мапі."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, пожалуйста, адрес на карте."
          }
        }
      }
    },
    "error.address.not_owned_by_user": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can't access this address."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "K této adrese nemáte přístup."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Môžete spravovať iba vlastné adresy."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете керувати лише власними адресами."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете управлять только своими адресами."
          }
        }
      }
    },
    "error.auth.google_type_error": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This account uses Google sign-in. Use the Google button."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento účet používá přihlášení přes Google. Použijte tlačítko Google."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento účet používa prihlásenie cez Google. Použite tlačidlo Google."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей обліковий запис використовує вхід через Google. Скористайтеся кнопкою Google."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта учётная запись использует вход через Google. Используйте кнопку Google."
          }
        }
      }
    },
    "error.auth.insufficient_privileges": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't have permission to do that."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nemáte oprávnění k této akci."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nemáte oprávnenie na túto akciu."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас немає дозволу на цю дію."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас нет разрешения на это действие."
          }
        }
      }
    },
    "error.auth.internal_type_error": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use email and password to sign in for this account."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro tento účet se přihlaste e-mailem a heslem."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pre tento účet sa prihláste e-mailom a heslom."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Для цього облікового запису увійдіть з email і паролем."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для этой учётной записи войдите по email и паролю."
          }
        }
      }
    },
    "error.auth.invalid_confirmation_code": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This code is invalid or has expired."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento kód je neplatný nebo vypršel."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento kód je neplatný alebo vypršal."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей код недійсний або застарів."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот код недействителен или истёк."
          }
        }
      }
    },
    "error.auth.invalid_google_token": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Google sign-in failed. Please try again."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlášení přes Google se nezdařilo. Zkuste to znovu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Prihlásenie cez Google sa nepodarilo. Skúste to znova."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося увійти через Google. Спробуйте знову."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось войти через Google. Попробуйте снова."
          }
        }
      }
    },
    "error.auth.invalid_password_format": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Password must be at least 8 characters with letters and numbers."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Heslo musí mít alespoň 8 znaků a obsahovat písmena a číslice."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Heslo musí mať aspoň 8 znakov a obsahovať písmená a číslice."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пароль має містити щонайменше 8 символів, літери та цифри."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пароль должен содержать минимум 8 символов, буквы и цифры."
          }
        }
      }
    },
    "error.auth.invalid_refresh_token": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your session expired. Please sign in again."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše přihlášení vypršelo. Přihlaste se prosím znovu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša relácia vypršala. Prihláste sa znova."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваша сесія завершилася. Увійдіть знову."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваша сессия истекла. Войдите снова."
          }
        }
      }
    },
    "error.auth.invalid_reset_token": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This password reset link is invalid or has expired."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento odkaz pro obnovení hesla je neplatný nebo vypršel."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento odkaz na obnovenie hesla je neplatný alebo vypršal."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це посилання для скидання пароля недійсне або застаріле."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта ссылка для сброса пароля недействительна или истекла."
          }
        }
      }
    },
    "error.auth.refresh_token_reused": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For your security, you've been signed out everywhere."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Z bezpečnostních důvodů jste byli odhlášeni ze všech zařízení."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Z bezpečnostných dôvodov ste boli odhlásení zo všetkých zariadení."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "З міркувань безпеки вас вийшли з усіх пристроїв."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В целях безопасности вы вышли со всех устройств."
          }
        }
      }
    },
    "error.auth.same_reset_password": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please choose a password different from your old one."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvolte prosím heslo odlišné od původního."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvoľte prosím heslo odlišné od pôvodného."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть пароль, відмінний від попереднього."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите пароль, отличный от старого."
          }
        }
