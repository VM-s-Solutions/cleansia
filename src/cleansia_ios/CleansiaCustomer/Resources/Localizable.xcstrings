    "recurring_bookings_empty_subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up a weekly or biweekly cleaning from a past order to skip the booking flow each time."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavte si týdenní nebo dvoutýdenní úklid z minulé objednávky a vyhněte se opětovnému objednávání."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavte si týždenné alebo dvojtýždenné upratovanie z minulej objednávky a vyhnite sa opätovnému objednávaniu."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштуйте щотижневе або раз на два тижні прибирання з минулого замовлення, щоб не оформлювати кожного разу."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте еженедельную или раз в две недели уборку из прошлого заказа, чтобы не оформлять каждый раз."
          }
        }
      }
    },
