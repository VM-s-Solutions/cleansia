    "devices_intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Devices signed in to your account. Removing a device signs it out and stops its notifications."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zařízení přihlášená k vašemu účtu. Odebráním zařízení jej odhlásíte a zastavíte jeho oznámení."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zariadenia prihlásené k vášmu účtu. Odstránením zariadenia ho odhlásite a zastavíte jeho oznámenia."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пристрої, що увійшли у ваш обліковий запис. Видалення пристрою вийде з нього й зупинить його сповіщення."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройства, вошедшие в ваш аккаунт. Удаление устройства выйдет из него и остановит его уведомления."
          }
        }
      }
    },
