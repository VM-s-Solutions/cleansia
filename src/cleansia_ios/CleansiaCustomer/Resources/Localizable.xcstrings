          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вхід через соцмережі не налаштовано в цій збірці."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вход через соцсети не настроен в этой сборке."
          }
        }
      }
    },
    "booking_all_slots_booked": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All slots booked for this day — try another date."
