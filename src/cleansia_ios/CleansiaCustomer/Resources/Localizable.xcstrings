    "profile_logout_dialog_message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You'll be signed out of this device. Your bookings and rewards stay on your account — just sign in again to pick up where you left off."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Budete odhlášeni z tohoto zařízení. Vaše rezervace a odměny zůstanou na vašem účtu — stačí se znovu přihlásit."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Budete odhlásení z tohto zariadenia. Vaše rezervácie a odmeny zostanú na vašom účte — stačí sa znova prihlásiť."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вас буде вийдено з цього пристрою. Ваші бронювання та винагороди залишаться на обліковому записі — просто увійдіть знову."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы выйдете на этом устройстве. Ваши заказы и бонусы останутся в аккаунте — просто войдите снова."
          }
        }
      }
    },
