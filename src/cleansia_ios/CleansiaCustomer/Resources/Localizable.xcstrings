    "help_faq_a1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open your booking from the Orders tab and tap \"Cancel\". Cancellations are free up to 24 hours before the cleaning start time."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Otevřete rezervaci na kartě Objednávky a klepněte na „Zrušit“. Zrušení je zdarma až 24 hodin před začátkem úklidu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Otvorte rezerváciu na karte Objednávky a ťuknite na „Zrušiť“. Zrušenie je zdarma až 24 hodín pred začiatkom upratovania."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відкрийте бронювання на вкладці Замовлення і натисніть «Скасувати». Скасування безкоштовне за 24 години до початку прибирання."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте заказ на вкладке Заказы и нажмите «Отменить». Отмена бесплатна за 24 часа до начала уборки."
          }
        }
      }
    },
    "help_faq_a2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add access instructions when booking (e.g., door code, key location). Cleaners wait up to 15 minutes; if we can't reach you, the booking may be cancelled."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Při rezervaci přidejte pokyny k přístupu (např. kód, umístění klíče). Uklízeči čekají až 15 minut; pokud vás nezastihneme, rezervace může být zrušena."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pri rezervácii pridajte pokyny na prístup (napr. kód, umiestnenie kľúča). Upratovači čakajú až 15 minút; ak vás nezastihneme, rezervácia môže byť zrušená."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додайте інструкції доступу при бронюванні (наприклад, код, місце ключа). Клінери чекають до 15 хвилин; якщо ми не зможемо до вас додзвонитися, бронювання може бути скасоване."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте инструкции по доступу при заказе (например, код, расположение ключа). Клинеры ждут до 15 минут; если мы не сможем связаться, заказ может быть отменён."
          }
        }
      }
    },
    "help_faq_a3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes. All Cleansia cleaners are background-checked and covered by insurance up to 1,000,000 CZK per booking."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ano. Všichni uklízeči Cleansia jsou prověřeni a pojištěni až do 1 000 000 Kč na rezervaci."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Áno. Všetci upratovači Cleansia sú preverení a poistení až do 1 000 000 CZK na rezerváciu."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Так. Усі клінери Cleansia перевірені та застраховані до 1 000 000 CZK за бронювання."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Да. Все клинеры Cleansia проверены и застрахованы до 1 000 000 CZK за заказ."
          }
        }
      }
    },
    "help_faq_a4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From the Orders tab, open the upcoming booking and tap \"Reschedule\". Free rescheduling up to 12 hours before the cleaning."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Na kartě Objednávky otevřete nadcházející rezervaci a klepněte na „Změnit termín“. Změna je zdarma až 12 hodin před úklidem."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Na karte Objednávky otvorte nadchádzajúcu rezerváciu a ťuknite na „Zmeniť termín“. Zmena je zdarma až 12 hodín pred upratovaním."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "На вкладці Замовлення відкрийте майбутнє бронювання і натисніть «Перенести». Безкоштовне перенесення за 12 годин до прибирання."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На вкладке Заказы откройте предстоящий заказ и нажмите «Перенести». Бесплатный перенос за 12 часов до уборки."
          }
        }
      }
    },
    "help_faq_a5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kitchen, bathrooms, all floors, dusting, and general tidying. Extras like oven cleaning are available as add-ons."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuchyně, koupelny, všechny podlahy, utírání prachu a úklid. Extra služby jako čištění trouby jsou jako doplňky."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuchyňa, kúpeľne, všetky podlahy, utieranie prachu a upratovanie. Extra služby ako čistenie rúry sú ako doplnky."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кухня, ванні, усі підлоги, витирання пилу та загальне прибирання. Додатково — чищення духовки тощо."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кухня, ванные, все полы, протирание пыли и общая уборка. Доп. услуги вроде чистки духовки — как дополнения."
          }
        }
      }
    },
