    "auth_social_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't sign in. Try again or use email."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlášení se nezdařilo. Zkuste to znovu nebo použijte e-mail."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Prihlásenie sa nepodarilo. Skúste znova alebo použite e-mail."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося увійти. Спробуйте ще раз або скористайтеся email."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось войти. Попробуйте снова или используйте email."
          }
        }
      }
    },
    "auth_social_no_account": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No account available on this device. Add one in Settings and try again."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V tomto zařízení není dostupný žádný účet. Přidejte ho v Nastavení a zkuste to znovu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "V tomto zariadení nie je dostupný žiadny účet. Pridajte ho v Nastaveniach a skúste znova."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "На цьому пристрої немає доступного облікового запису. Додайте його в Налаштуваннях і спробуйте ще раз."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом устройстве нет доступного аккаунта. Добавьте его в Настройках и попробуйте снова."
          }
        }
      }
    },
    "auth_social_not_configured": {
      "extractionState": "manual",
      "localizations": {
