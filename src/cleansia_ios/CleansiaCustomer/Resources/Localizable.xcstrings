    "recurring_bookings_delete_dialog_what_stays": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cleanings already on your calendar stay booked — cancel them individually from Orders if you no longer want them."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Úklidy už zařazené v kalendáři zůstávají potvrzené — pokud je nechcete, zrušte je jednotlivě v Objednávkách."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Upratovania už zaradené v kalendári zostávajú potvrdené — ak ich nechcete, zrušte ich jednotlivo v Objednávkach."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прибирання, які вже у календарі, залишаються — скасуйте їх по одному в Замовленнях, якщо більше не потрібні."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уборки, уже в календаре, останутся — отмените их по одной в Заказах, если они больше не нужны."
          }
        }
      }
    },
    "recurring_bookings_delete_dialog_what_stops": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No new cleanings will be auto-booked from this schedule."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Z tohoto rozvrhu už nebudou automaticky vznikat žádné nové úklidy."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Z tohto rozvrhu už nebudú automaticky vznikať žiadne nové upratovania."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "З цього розкладу більше не створюватимуться нові прибирання автоматично."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из этого расписания больше не будут автоматически создаваться новые уборки."
          }
        }
      }
    },
