    "devices_error_message": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zařízení se nepodařilo načíst. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn't load your devices. Check your connection and try again."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить устройства. Проверьте подключение и повторите попытку."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zariadenia sa nepodarilo načítať. Skontrolujte pripojenie a skúste to znova."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося завантажити пристрої. Перевірте з'єднання та спробуйте ще раз."
          }
        }
      }
    },
    "devices_intro": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zařízení přihlášená k vašemu účtu. Odebráním zařízení dojde k jeho odhlášení a vypnutí oznámení."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Devices signed in to your account. Removing a device signs it out and stops its notifications."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройства, на которых выполнен вход в ваш аккаунт. Удаление устройства завершает его сеанс и отключает уведомления."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zariadenia prihlásené k vášmu účtu. Odobratím zariadenia ho odhlásite a vypnete jeho upozornenia."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пристрої, на яких виконано вхід у ваш обліковий запис. Видалення пристрою завершує його сеанс і вимикає сповіщення."
          }
        }
      }
    },
