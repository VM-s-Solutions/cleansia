    },
    "onboarding_welcome_body": {
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Spravujte své úklidové zakázky, sledujte výdělky a rozšiřujte svou klientskou základnu — vše na jednom místě."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage your cleaning jobs, track your earnings, and grow your client base — all in one place."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляйте заказами на уборку, отслеживайте заработок и расширяйте клиентскую базу — всё в одном месте."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Spravujte svoje upratovacie zákazky, sledujte zárobky a rozširujte si klientelu — všetko na jednom mieste."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Керуйте замовленнями на прибирання, відстежуйте заробіток і розширюйте клієнтську базу — все в одному місці."
          }
        }
      }
    },
