# Copy this file to  fastlane/.env  and fill in your values.
# fastlane auto-loads fastlane/.env; it is gitignored — NEVER commit real values.
#
# All four come from your Apple account and are used only on your Mac.

# --- App Store Connect API key ---
# App Store Connect ▸ Users and Access ▸ Integrations ▸ Keys ▸ (+).
# Download the .p8 ONCE (you cannot re-download it) and store it outside the repo.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=/Users/you/.appstoreconnect/AuthKey_XXXXXXXXXX.p8

# --- Signing ---
# Your 10-character Apple Developer Team ID (Membership details in the portal).
# Passed to xcodebuild as DEVELOPMENT_TEAM, so you do NOT edit project.yml.
ASC_TEAM_ID=XXXXXXXXXX
